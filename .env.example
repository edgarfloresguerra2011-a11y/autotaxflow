# Entorno General
NODE_ENV="development"
PORT=3001

# Base de Datos (PostgreSQL via Docker local)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://autotaxflow_user:autotaxflow_password@localhost:5432/autotaxflow_dev?schema=public"

# Redis (Colas y Caché)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Seguridad y Autenticación
# Secreto para JWT o cookies (en prod, usa una clave aleatoria fuerte)
SESSION_SECRET="super-secret-autotaxflow-development-key-123"

# Integración: Stripe
# Claves de prueba de Stripe Dashboard
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CLIENT_ID="ca_..."

# Integración: QuickBooks Online (QBO)
# Claves de la app Intuit Developer Sandbox
QBO_CLIENT_ID="AB..."
QBO_CLIENT_SECRET="xy..."
QBO_ENVIRONMENT="sandbox" # En produccion: "production"
QBO_REDIRECT_URI="http://localhost:3000/api/auth/callback/qbo"

# Storage (S3 / R2 - Opcional para MVP Local)
AWS_REGION="auto"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME="autotaxflow-exports-dev"
AWS_S3_ENDPOINT="" # Ej: "https://<account-id>.r2.cloudflarestorage.com"
